# ── CryptoRadar — Переменные окружения ──
# Скопируй этот файл: cp .env.example .env
# Заполни реальными значениями

# OpenRouter (DeepSeek)
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxx

# Telegram Bot
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_CHAT_ID=-1001234567890

# Bybit API (опционально, для будущих фич)
BYBIT_API_KEY=
BYBIT_API_SECRET=

# Настройки (опционально, есть дефолты)
# SCAN_INTERVAL=60
# TOP_N_COINS=30
# MIN_SCORE=3
# DEEPSEEK_MODEL=deepseek/deepseek-chat-v3-0324
# LOG_DIR=logs
