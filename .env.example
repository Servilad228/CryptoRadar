# ── CryptoRadar — Переменные окружения ──
# Скопируй этот файл: cp .env.example .env
# Заполни реальными значениями

# OpenRouter (для всех AI моделей)
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxx

# Telegram Bot
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_CHAT_ID=-1001234567890

# Bybit API (нужны для Demo и Battle режимов)
BYBIT_API_KEY=
BYBIT_API_SECRET=

# ── AI Models (3 роли) ──
ANALYZER_MODEL=deepseek/deepseek-chat-v3-0324    # первичный анализ монеты
ORDER_MODEL=anthropic/claude-3.7-sonnet           # генерация ордеров
REVIEW_MODEL=anthropic/claude-3.7-sonnet          # разбор полётов (уроки)
MAX_TIPS_IN_PROMPT=10                             # сколько советов вставлять в промпт

# ── Trading ──
TRADING_MODE=demo              # demo | battle
TARGET_PROFIT_USD=15.0         # целевой профит в USD
RR_MIN=1.5                     # минимальный Risk/Reward
RR_MAX=3.0                     # максимальный Risk/Reward
BREAKEVEN_TRIGGER_PCT=40.0     # % пути к TP для переноса SL в безубыток

# ── Position Tracking ──
DEMO_CHECK_INTERVAL_MIN=10     # интервал проверки позиций в Demo (минуты)

# ── Настройки (опционально, есть дефолты) ──
# SCAN_INTERVAL=60
# TOP_N_COINS=30
# MIN_SCORE_TOTAL=11
# LOG_DIR=logs
# DB_PATH=data/cryptoradar.db
